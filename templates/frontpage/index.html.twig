{% extends 'layout.html.twig' %}

{% block pre_body %}
    <div class="container-fluid p-0 m-0 w-100 jumbotron">
        <img
            alt="{{ 'GEWIS room impression'|trans }}"
            src="{{ asset('images/panorama-960.webp') }}"
            srcset="{{ asset('images/panorama-320.webp') }} 320w,
            {{ asset('images/panorama-480.webp') }} 480w,
            {{ asset('images/panorama-640.webp') }} 640w,
            {{ asset('images/panorama-960.webp') }} 960w,
            {{ asset('images/panorama-1280.webp') }} 1280w,
            {{ asset('images/panorama-1920.webp') }} 1920w,
            {{ asset('images/panorama-2560.webp') }} 2560w,
            {{ asset('images/panorama-3840.webp') }} 3840w,
            {{ asset('images/panorama-4096.webp') }} 4096w,
            {{ asset('images/panorama-4480.webp') }} 4480w,
            {{ asset('images/panorama-5120.webp') }} 5120w"
            class="img-fluid">
    </div>
{% endblock %}

{% block contents %}
    <div class="row">
        <main class="col-sm-7 col-md-8">
            <section class="my-2">
                <h1 class="display-6">{{ 'Study Association GEWIS'|trans }}</h1>
                <p class="lead">
                    {{ 'Welcome to the website of study association GEWIS, the study association of the department of Mathematics & Computer Science at Eindhoven University of Technology.'|trans }}
                </p>
            </section>
            <section class="mb-2">
                <h2>{{ 'News'|trans }}</h2>
            </section>
            {# Birthday data is member-only, so the block is gated on an authenticated session. #}
            {% if birthdays is not empty and is_granted('ROLE_USER') %}
                <section class="my-2">
                    <div class="panel overflow-hidden">
                        <div class="row g-0">
                            {% if birthdayPhoto is not null %}
                                {% set birthday_url = path('photo/album', { type: 'album', album: birthdayPhoto.album.id }) ~ '#pid=' ~ birthdayPhoto.id %}
                                <div class="col-md-6">
                                    <a href="{{ birthday_url }}">
                                        <img class="img-fluid w-100" alt=""
                                             src="{{ image_url(birthdayPhoto.path, 'w320') }}"
                                             srcset="{{ image_srcset(birthdayPhoto.path, ['w320', 'w640']) }}"
                                             sizes="(min-width: 768px) 33vw, 100vw">
                                    </a>
                                </div>
                            {% endif %}
                            <div class="col-md-{{ birthdayPhoto is null ? '12' : '6' }}">
                                <div class="panel-heading">
                                    <h3>{{ 'Birthdays'|trans }}</h3>
                                </div>
                                <div class="panel-body">
                                    <ul class="mb-0">
                                        {% for birthday in birthdays %}
                                            <li>{{ '%name% turns %age% today!'|trans({
                                                '%name%': birthday.member.fullName,
                                                '%age%': birthday.age,
                                            }) }}</li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            {% endif %}
        </main>
        <aside class="col-sm-5 col-md-4 ps-md-5">
            <div class="panel">
                <div class="panel-heading">
                    <h3>{{ 'Agenda'|trans }}</h3>
                </div>
                {% if activities is not empty %}
                    <div class="list-group list-group-flush">
                        {% for activity in activities %}
                            <a class="list-group-item list-group-item-action"
                               href="{{ path('') }}">
                                <h4 class="list-group-item-heading">{{ activity.getName.getText|localise_text }}</h4>
                                <p class="list-group-item-text text-muted">{{ activity.getBeginTime|format_datetime('full', 'short', locale: app.request.locale)|capitalize }}</p>
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
                <div class="panel-body">
                    <small>
                        {% trans with {'%link_start%': '<a href="https://bac.gewis.nl">', '%link_end%': '</a>'} %}
                            On Thursdays, there is a %link_start%social drink%link_end% from 16.30 to 19.00.
                        {% endtrans %}
                    </small>
                </div>
                <div class="panel-footer">
                    <a href="{{ path('activity/index') }}" class="panel-footer-link">
                        {{ 'Complete agenda'|trans }}
                    </a>
                    <a
                        href="https://www.google.com/calendar/embed?src=v23gq10ij44fhdsfdof1s613ak%40group.calendar.google.com&gsessionid=OK"
                        title="{{ 'Google Calendar'|trans }}"
                        class="panel-footer-link"
                    >
                        {{ 'iCal'|trans }}
                    </a>
                </div>
            </div>

            {#
                The photo of the week. Members fetch the signed members-only original; anonymous visitors are served the
                public copy the weekly command publishes, and only while it is not hidden.
            #}
            {% if weeklyPhoto is not null and (is_granted('ROLE_USER') or (not weeklyPhoto.hidden and weeklyPublicPath is not null)) %}
                {% set potw = weeklyPhoto.photo %}
                {% set potw_url = path('photo/album', { type: 'album', album: potw.album.id }) ~ '#pid=' ~ potw.id %}
                {% set potw_path = is_granted('ROLE_USER') ? potw.path : weeklyPublicPath %}
                <div class="panel">
                    <div class="panel-heading">
                        <h3><a href="{{ potw_url }}">{{ 'Photo of the Week'|trans }}</a></h3>
                    </div>
                    <div class="panel-thumb">
                        <a href="{{ potw_url }}">
                            <img class="img-fluid" alt=""
                                 src="{{ image_url(potw_path, 'w320') }}"
                                 srcset="{{ image_srcset(potw_path, ['w320', 'w640']) }}"
                                 sizes="(min-width: 768px) 33vw, 100vw">
                        </a>
                    </div>
                </div>
            {% endif %}
        </aside>
    </div>
{% endblock %}

{% extends 'layout.html.twig' %}

{% block page_title %}{{ 'Manage your sign-up'|trans|page_title }}{{ parent() }}{% endblock %}

{% block contents %}
    <div class="row justify-content-center">
        <div class="col col-sm-10 col-lg-6 col-xl-4">
            <h3 class="mb-1">{{ 'Manage your sign-up'|trans }}</h3>
            <p class="text-muted">
                <a href="{{ path('activity/view', {'activity': activity.getId}) }}">{{ activity_title(activity) }}</a>
            </p>

            <div class="panel">
                <div class="panel-body">
                    <twig:Activity:ExternalSignupManage :token="token" />
                </div>
            </div>
        </div>
    </div>

    {% include 'partials/application/confirm-modal.html.twig' %}
{% endblock %}

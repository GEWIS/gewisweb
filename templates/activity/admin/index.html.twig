{% extends 'layout-admin.html.twig' %}

{% block page_title %}{{ 'Overview'|trans|page_title }}{{ 'Activities'|trans|page_title }}{{ parent() }}{% endblock %}

{% block admin_breadcrumbs %}
    <li class="breadcrumb-item active" aria-current="page">
        <a href="{{ path('admin/activities/index') }}">
            {{ 'Activities'|trans }}
        </a>
    </li>
    <li class="breadcrumb-item active" aria-current="page">
        {{ 'Overview'|trans }}
    </li>
{% endblock %}

{% block contents %}
    <div class="row mb-3">
        <div class="col-md-12 d-flex justify-content-between align-items-center">
            <h1 class="h3 mb-0">{{ 'Activities'|trans }}</h1>
            <a href="{{ path('admin/activities/create') }}" class="btn btn-gewis-primary">
                <i class="fas fa-plus"></i> {{ 'Create activity'|trans }}
            </a>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <twig:Activity:Admin:ActivityOverview />
        </div>
    </div>
{% endblock %}

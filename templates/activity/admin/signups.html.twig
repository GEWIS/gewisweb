{% extends 'layout-admin.html.twig' %}

{% block page_title %}{{ 'Sign-ups'|trans|page_title }}{{ activity_title(activity)|page_title }}{{ parent() }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/ckeditor5/ckeditor5.css') }}">
{% endblock %}

{% block admin_breadcrumbs %}
    <li class="breadcrumb-item">
        <a href="{{ path('admin/activities/index') }}">
            {{ 'Activities'|trans }}
        </a>
    </li>
    <li class="breadcrumb-item active" aria-current="page">
        {{ activity_title(activity) }}
    </li>
    <li class="breadcrumb-item active" aria-current="page">
        {{ 'Sign-ups'|trans }}
    </li>
{% endblock %}

{% block contents %}
    <div class="row">
        <div class="col-md-12 d-flex justify-content-between align-items-center gap-2">
            <div>
                <h3 class="mb-1">{{ 'Sign-ups'|trans }}</h3>
                <p class="text-muted mb-0">
                    {{ activity_title(activity) }}
                    &middot;
                    {{ activity.getBeginTime|format_datetime(pattern: 'EEE d MMM. yyyy HH:mm', locale: app.request.locale) }}
                </p>
            </div>
            <a href="{{ path('admin/activities/index') }}" class="btn btn-outline-secondary">
                <span class="fas fa-arrow-left"></span> {{ 'Back to overview'|trans }}
            </a>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
            <twig:Activity:Admin:SignupOverview :activity="activity" />
        </div>
    </div>

    {% include 'partials/application/confirm-modal.html.twig' %}
{% endblock %}

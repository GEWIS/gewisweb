{% extends 'layout-admin.html.twig' %}

{% block page_title %}{{ 'Create Activity'|trans|page_title }}{{ 'Activities'|trans|page_title }}{{ parent() }}{% endblock %}

{% block admin_breadcrumbs %}
    <li class="breadcrumb-item active" aria-current="page">
        <a href="{{ path('admin/activities/index') }}">
            {{ 'Activities'|trans }}
        </a>
    </li>
    <li class="breadcrumb-item active" aria-current="page">
        {{ 'Create'|trans }}
    </li>
{% endblock %}

{% block contents %}
    <div class="row">
        <div class="col-md-12">
            <h1 class="h3 mb-3">{{ 'Create activity'|trans }}</h1>
            {% include 'partials/activity/admin/form.html.twig' with {'form': form, 'submitLabel': 'Save draft'|trans} only %}
        </div>
    </div>
{% endblock %}

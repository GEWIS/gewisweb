<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    {# A document-level meta refresh, rather than a Location header, so the cross-origin navigation after the POST is
       not caught by the enforced `form-action` CSP directive. #}
    <meta http-equiv="refresh" content="0;url={{ url }}">
    <meta name="robots" content="noindex">
    <title>{{ 'Redirecting'|trans }}</title>
    <style>
        body { font-family: system-ui, sans-serif; margin: 3rem auto; max-width: 32rem; padding: 0 1rem; color: #333; }
    </style>
</head>
<body>
    <p>{{ 'You are being redirected to %app%.'|trans({'%app%': appId}) }}</p>
    <p>
        {% set link %}<a href="{{ url }}">{{ 'continue'|trans }}</a>{% endset %}
        {{ 'If your browser does not redirect you, %link% manually.'|trans({'%link%': link})|raw }}
    </p>
</body>
</html>

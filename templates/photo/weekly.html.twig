{% extends 'layout.html.twig' %}

{% block page_title %}{{ 'Photo of the Week'|trans|page_title }}{{ parent() }}{% endblock %}

{% block contents %}
    <h1 class="mb-4">{{ 'Photo of the Week'|trans }}</h1>

    {% if photosByYear is empty %}
        <p class="text-muted">{{ 'No photo of the week has been chosen yet.'|trans }}</p>
    {% else %}
        {% if current is not null %}
            <div class="row justify-content-center mb-4">
                <div class="col col-lg-8 col-xl-6">
                    <a href="{{ path('photo/album', { type: 'album', album: current.photo.album.id }) }}#pid={{ current.photo.id }}"
                       class="text-decoration-none">
                        <div class="panel my-0">
                            <div class="panel-thumb">
                                <img class="img-fluid w-100" alt=""
                                     src="{{ image_url(current.photo.path, 'w960') }}">
                            </div>
                            <div class="panel-body">
                                <h5 class="mb-1 text-body">{{ 'Current photo of the week'|trans }}</h5>
                                <p class="small text-muted mb-0">{{ current.photo.album.name }}</p>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        {% endif %}

        {# One virtual weekly album per association year; open it to browse that year's photos of the week. #}
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
            {% for year, weeklies in photosByYear %}
                {% set cover = weeklies|first.photo %}
                <div class="col">
                    <a href="{{ path('photo/album', { type: 'weekly', album: year }) }}" class="text-decoration-none">
                        <div class="panel h-100 my-0">
                            <div class="ratio ratio-16x9 bg-body-secondary rounded-top overflow-hidden">
                                <img class="w-100 h-100" style="object-fit: cover;" loading="lazy"
                                     src="{{ image_url(cover.path, 'w640') }}" alt="">
                            </div>
                            <div class="panel-body">
                                <h6 class="mb-1 text-body">
                                    {{ year }}/{{ year + 1 }}
                                </h6>
                                <p class="small text-muted mb-0">
                                    <span class="fa-solid fa-image me-1"></span>{{ weeklies|length }}
                                    {{ weeklies|length == 1 ? 'photo'|trans : 'photos'|trans }}
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}

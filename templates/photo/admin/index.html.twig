{% extends 'layout-admin.html.twig' %}

{% block page_title %}{{ 'Overview'|trans|page_title }}{{ 'Photos'|trans|page_title }}{{ parent() }}{% endblock %}

{% block admin_breadcrumbs %}
    <li class="breadcrumb-item active" aria-current="page">
        <a href="{{ path('admin/photos/index') }}">
            {{ 'Photos'|trans }}
        </a>
    </li>
    <li class="breadcrumb-item active" aria-current="page">
        {{ 'Overview'|trans }}
    </li>
{% endblock %}

{% block contents %}
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <h1 class="h3 mb-0">{{ 'Photo albums'|trans }}</h1>
        <div class="d-flex flex-wrap align-items-center gap-2">
            {% if years is not empty %}
                {% include 'partials/year-switcher.html.twig' with {
                    route: 'admin/photos/index',
                    year: year,
                    years: years,
                    all_years: false,
                } only %}
            {% endif %}
            <a href="{{ path('admin/photos/albums_create') }}" class="btn btn-gewis-primary">
                <i class="fas fa-plus"></i> {{ 'Create album'|trans }}
            </a>
        </div>
    </div>

    {% if albums is empty %}
        <p class="text-muted">{{ 'There are no albums yet.'|trans }}</p>
    {% else %}
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xxl-6 g-3 mb-4">
            {% for album in albums %}
                {% include 'partials/photo/admin/album-card.html.twig' with {
                    'album': album,
                    'subAlbumCount': cardCounts.subAlbums[album.id] ?? 0,
                    'photoCount': cardCounts.photos[album.id] ?? 0,
                } only %}
            {% endfor %}
        </div>

        {# A per-album confirmation modal wrapping the POST form, so a delete is never a bare browser dialog. #}
        {% for album in albums %}
                <div class="modal fade" id="delete-album-{{ album.id }}" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">{{ 'Delete album'|trans }}</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"
                                        aria-label="{{ 'Close'|trans }}"></button>
                            </div>
                            <div class="modal-body">
                                <p>{{ 'Are you sure you want to delete this album?'|trans }}</p>
                                <p class="fw-semibold mb-0">{{ album.name }}</p>
                                {% if album.albumCount > 0 or album.getPhotoCount(false) > 0 %}
                                    <p class="text-danger small mt-2 mb-0">
                                        <i class="fa-solid fa-triangle-exclamation me-1"></i>
                                        {{ 'Its sub-albums and photos are deleted as well. This cannot be undone.'|trans }}
                                    </p>
                                {% endif %}
                            </div>
                            <form method="post" action="{{ path('admin/photos/albums_delete', {album: album.id}) }}">
                                <input type="hidden" name="_csrf_token"
                                       value="{{ csrf_token('photo_album_delete-' ~ album.id) }}">
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-link"
                                            data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                                    <button type="submit" class="btn btn-danger">{{ 'Delete album'|trans }}</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
        {% endfor %}
    {% endif %}
{% endblock %}

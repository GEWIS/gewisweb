{% extends 'base.html.twig' %}

{% block body %}
    <div class="container-fluid container-admin flex-grow-1 d-flex flex-row px-0">
        <aside class="px-0 sticky-top">
            <nav class="navbar-sidebar navbar-gewis-admin rainbow d-flex flex-column h-100">
                <div class="navbar-header d-lg-none d-flex justify-content-center">
                    <button class="navbar-toggler p-2" type="button" data-bs-toggle="offcanvas"
                            data-bs-target="#navbar-sidebar-offcanvas" aria-controls="navbar-sidebar-offcanvas"
                            aria-expanded="false" aria-label="{{ 'Toggle navigation'|trans }}">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>
                <div class="offcanvas-lg offcanvas-start h-100" id="navbar-sidebar-offcanvas"
                     tabindex="-1" aria-labelledby="navbar-sidebar-offcanvas-label">
                    <div class="offcanvas-header d-lg-none">
                        <h5 class="offcanvas-title" id="navbar-sidebar-offcanvas-label">
                            {% block sidebar_label %}{{ 'Navigation'|trans }}{% endblock %}
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"
                                data-bs-target="#navbar-sidebar-offcanvas" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="offcanvas-body p-4 pt-0 p-lg-0 h-100">
                        <ul class="navbar-nav h-100 w-100">
                            <hr class="d-lg-none">
                            {% block sidebar %}{% endblock %}
                        </ul>
                    </div>
                </div>
            </nav>
        </aside>
        <main class="container-fluid flex-grow-1 p-0">
            {% if block('breadcrumbs') is defined and block('breadcrumbs')|trim != '' %}
                <nav class="navbar-breadcrumb sticky-top" aria-label="breadcrumb">
                    <ol class="breadcrumb m-0 px-2">
                        {% block breadcrumbs %}{% endblock %}
                    </ol>
                </nav>
            {% endif %}
            <section class="mx-auto my-0 pt-2 px-3 overflow-x-auto">
                {% block contents %}{% endblock %}
            </section>
        </main>
    </div>
{% endblock %}

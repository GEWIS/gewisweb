<div aria-live="polite" aria-atomic="true" class="position-sticky bottom-0">
    <div class="toast-container bottom-0 end-0 p-3">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="toast toast-{{ label }} align-items-center fade" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="5000">
                    <div class="d-flex">
                        <div class="toast-body">
                            {{ message }}
                        </div>
                        <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
</div>
<script nonce="{{ csp_nonce('script') }}">
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.toast').forEach((toast, index) => {
            setTimeout(() => {
                bootstrap.Toast.getOrCreateInstance(toast).show();
            }, index * 10);
        });
    });
</script>

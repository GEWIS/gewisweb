                    {{ 'Enable MFA now'|trans }}
                </a>
            </strong>
        </p>
    </div>
{% endif %}
{% if is_granted('ROLE_ADMIN') or is_granted('IS_IMPERSONATOR') %}
    {# Always show impersonator notice first, to show that other notices are the effect of the impersonation. #}
    {% if is_granted('IS_IMPERSONATOR') %}
        <div class="special-notice impersonator-notice sticky-top">
            <p class="text-center">
                <strong>
                    {{ 'You are currently impersonating %name% (%lidnr%)!'|trans({'%name%': app.user.getMember.getFullName, '%lidnr%': app.user.getMember.getLidnr}) }}
                    <a href="{{ impersonation_exit_path(path('frontpage/index')) }}">
                        {{ 'Exit impersonation'|trans }}
                    </a>
                </strong>
            </p>
        </div>
    {% endif %}
    {% if is_granted('ROLE_ADMIN') %}
        <div class="special-notice admin-notice sticky-top">
            <p class="text-center">
                <strong>
                    {{ 'You are currently using administrator privileges to use the website!'|trans }}
                </strong>
            </p>
        </div>
    {% endif %}

                                {# Use route-based localisation when available. #}
                                {% set altlang_url = page is not defined ? path(app.current_route, app.current_route_parameters|merge({_locale: locale})) : localised_page_path(page, locale) %}
                            {% else %}
                                {# Otherwise, we are in an error-state and construct the URL manually. #}
                                {% set current_path = app.request.pathinfo %}
                                {% if current_path starts with '/' ~ app.request.locale ~ '/' %}
                                    {% set stripped_path = current_path|slice((app.request.locale|length + 1)) %}
                                {% else %}
                                    {% set stripped_path = current_path %}
                                {% endif %}


{% set overviewHref = isSelf ? path('members/me') : path('members/view', {'member': member.lidnr}) %}
{% set photosHref = path('photo/album', {'type': 'member', 'album': member.lidnr}) %}

<li class="nav-item {{ activeRoute == 'overview' ? 'active' : '' }}">
    <a class="nav-link p-3" href="{{ overviewHref }}">
        {{ 'Overview'|trans }}
    </a>
</li>
<li class="nav-item {{ activeRoute == 'photos' ? 'active' : '' }}">
    <a class="nav-link p-3" href="{{ photosHref }}">
        {{ 'Photos'|trans }}
    </a>
</li>
{% if isSelf %}
    {% set settingsActive = activeRoute in ['general', 'privacy', 'security'] %}
    <li class="nav-item dropdown dropend {{ settingsActive ? 'active default open' : '' }}">
        <a class="nav-link p-3 dropdown-toggle"
           href="#" data-bs-toggle="dropdown" data-bs-offset="0,0" aria-expanded="{{ settingsActive ? 'true' : 'false' }}">
            {{ 'Settings'|trans }}
        </a>
        <ul class="dropdown-menu">
            <li>
                <a class="dropdown-item {{ activeRoute == 'general' ? 'active' : '' }}" href="{{ path('user_settings_general') }}">
                    {{ 'General'|trans }}
                </a>
            </li>
            <li>
                <a class="dropdown-item {{ activeRoute == 'privacy' ? 'active' : '' }}" href="{{ path('user_settings_index') }}">
                    {{ 'Privacy'|trans }}
                </a>
            </li>
            <li>
                <a class="dropdown-item {{ activeRoute == 'security' ? 'active' : '' }}" href="{{ path('user_security_index') }}">
                    {{ 'Security'|trans }}
                </a>
            </li>
        </ul>
    </li>
{% endif %}

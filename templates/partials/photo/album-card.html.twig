<div class="col">
    <a href="{{ path('photo/album', { type: 'album', album: album.id }) }}" class="text-decoration-none">
        <div class="panel h-100 my-0">
            <div class="ratio ratio-16x9 bg-body-secondary rounded-top overflow-hidden">
                {% if album.coverPath %}
                    <img class="w-100 h-100"
                         style="object-fit: cover;"
                         loading="lazy"
                         src="{{ image_url(album.coverPath, 'cover') }}"
                         alt="">
                {% else %}
                    {# No generated cover yet; show a neutral placeholder rather than a broken image. #}
                    <div class="d-flex align-items-center justify-content-center text-muted h-100">
                        <span class="fa-solid fa-images fa-2x"></span>
                    </div>
                {% endif %}
            </div>
            <div class="panel-body">
                <h6 class="mb-1 text-body">
                    {% if album.createdAt >= date('-1 week') %}
                        <span class="badge badge-gewis-primary align-middle me-1">{{ 'New'|trans }}</span>
                    {% endif %}
                    {{ album.name }}
                </h6>
                {% include 'partials/photo/album-dates.html.twig' with { 'album': album } only %}
                <p class="small text-muted mb-0">
                    {# subAlbumCount/photoCount are batched by the overview; fall back to the lazy counts elsewhere. #}
                    {% set subAlbums = subAlbumCount ?? album.publishedAlbumCount %}
                    {% if subAlbums > 0 %}
                        <span class="fa-solid fa-folder-open me-1"></span>{{ subAlbums }}
                        {{ subAlbums == 1 ? 'sub-album'|trans : 'sub-albums'|trans }}
                    {% else %}
                        {% set photos = photoCount ?? album.getPhotoCount(false) %}
                        <span class="fa-solid fa-image me-1"></span>{{ photos }}
                        {{ photos == 1 ? 'photo'|trans : 'photos'|trans }}
                    {% endif %}
                </p>
            </div>
        </div>
    </a>
</div>

{# Accordion panel for one sign-up list. Params: `list` (SignupListView), `collapseId` (string), `open` (bool). The
   member body is the Activity:SignupList live component; the guest external sign-up is the Activity:ExternalSignupForm
   live component (both inside Bootstrap modals whose chrome is server-rendered here). #}
<div class="panel mb-3">
    <button type="button"
            class="panel-heading signup-list-heading d-flex justify-content-between align-items-start gap-2 w-100 border-0 bg-transparent text-start {% if not open %}collapsed{% endif %}"
            data-bs-toggle="collapse" data-bs-target="#{{ collapseId }}"
            aria-expanded="{{ open ? 'true' : 'false' }}" aria-controls="{{ collapseId }}">
        <span>
            <span class="d-flex flex-wrap align-items-center gap-1 mb-1">
                <span class="h5 mb-0">{{ list.name }}</span>
                {% if list.promoted %}
                    <i class="fas fa-star text-warning" title="{{ 'Promoted'|trans }}"></i>
                {% endif %}
            </span>
            <span class="d-flex flex-wrap align-items-center gap-1 mb-1">
                {% if list.isOpen %}
                    <span class="badge badge-success">{{ 'Open'|trans }}</span>
                {% elseif list.isClosed %}
                    <span class="badge badge-danger">{{ 'Closed'|trans }}</span>
                {% else %}
                    <span class="badge badge-info">{{ 'Not yet open'|trans }}</span>
                {% endif %}
                {% if list.limitedCapacity %}
                    <span class="badge badge-warning">
                        {%- if list.capacity is not null -%}
                            {{ 'Limited capacity (%capacity%)'|trans({'%capacity%': list.capacity}) }}
                        {%- else -%}
                            {{ 'Limited capacity'|trans }}
                        {%- endif -%}
                    </span>
                {% endif %}
                {% if list.onlyGEWIS %}
                    <span class="badge badge-tag">{{ 'GEWIS members only'|trans }}</span>
                {% endif %}
            </span>
            <small class="text-muted d-block">
                {{ 'Open from %open% until %close%.'|trans({
                    '%open%': list.openDate|format_datetime(pattern: 'EEE d MMM. yyyy HH:mm', locale: app.request.locale),
                    '%close%': list.closeDate|format_datetime(pattern: 'EEE d MMM. yyyy HH:mm', locale: app.request.locale),
                }) }}
            </small>
        </span>
        <i class="fas fa-chevron-down signup-list-chevron"></i>
    </button>
    <div class="collapse {% if open %}show{% endif %}" id="{{ collapseId }}">
        {# `pt-0`: the heading already supplies bottom padding, and the `.collapse` wrapper defeats the panel's
           `.panel-heading + .panel-body { padding-top: 0 }` rule, so without this the body's top padding doubles it. #}
        <div class="panel-body pt-0">
            {% if is_granted('ROLE_USER') %}
                {# The member-facing body (buttons, sign-up modal and subscriber table) is a live component, so signing
                   up, editing and unsubscribing all update inline. Unsubscribe is driven by the page-level
                   #confirm-modal (included once in the activity view). #}
                <twig:Activity:SignupList :signupList="list.listId" />
            {% else %}
                {# Guests: the external sign-up uses a plain Bootstrap modal + form (its Altcha captcha cannot live in a
                   live component); an invalid submit re-renders the page and re-opens this modal with the errors. #}
                {% if list.isOpen %}
                    {% if list.onlyGEWIS %}
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                            <a class="btn btn-sm btn-gewis-primary" href="{{ path('user_login') }}">{{ 'Log in to sign up'|trans }}</a>
                        </div>
                    {% elseif not list.onlyGEWIS %}
                        {% set externalModalId = 'signup-external-modal-' ~ list.listId %}
                        {% set resendModalId = 'resend-modal-' ~ list.listId %}
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                            <div class="btn-group btn-group-sm" role="group"
                                 aria-label="{{ 'Sign up as a guest'|trans }}">
                                <button type="button" class="btn btn-gewis-primary"
                                        data-bs-toggle="modal" data-bs-target="#{{ externalModalId }}">
                                    <i class="fas fa-user-plus"></i> {{ 'Sign up as a guest'|trans }}
                                </button>
                                <button type="button" class="btn btn-outline-gewis-primary"
                                        data-bs-toggle="modal" data-bs-target="#{{ resendModalId }}">
                                    {{ "Did not receive the confirmation email? Resend it."|trans }}
                                </button>
                            </div>
                            <a class="btn btn-sm btn-link" href="{{ path('user_login') }}">
                                {{ 'Have a GEWIS account? Log in to sign up.'|trans }}
                            </a>
                        </div>

                        <div class="modal fade" id="{{ externalModalId }}" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">{{ "Sign up for '%name%'"|trans({'%name%': list.name}) }}</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                                aria-label="{{ 'Close'|trans }}"></button>
                                    </div>
                                    <twig:Activity:ExternalSignupForm :signupList="list.listId" />
                                </div>
                            </div>
                        </div>

                        {# Recovery path for a lost/undelivered confirmation email: a plain rate-limited form (no captcha
                           — it creates no data, only remails an address that already has a pending sign-up) that always
                           reports the same neutral result, so it never reveals whether an address is signed up. #}
                        <div class="modal fade" id="{{ resendModalId }}" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">{{ 'Resend confirmation email'|trans }}</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                                aria-label="{{ 'Close'|trans }}"></button>
                                    </div>
                                    <twig:Activity:ExternalSignupResendForm :signupList="list.listId" />
                                </div>
                            </div>
                        </div>
                    {% endif %}
                {% endif %}

                {% if list.displaySubscribedNumber %}
                    <p class="mb-1">{{ 'Number of subscriptions: %count%'|trans({'%count%': list.subscriberCount}) }}</p>
                {% endif %}
                <a href="{{ path('user_login') }}">{{ 'Log in to view the subscribers.'|trans }}</a>
            {% endif %}
        </div>
    </div>
</div>

<div {{ attributes }}>
    <div class="panel mb-3">
        <div class="panel-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-12">
                    <label class="form-label" for="company-users-overview-search">{{ 'Search'|trans }}</label>
                    <input type="search" class="form-control" id="company-users-overview-search"
                           placeholder="{{ 'Search by company, representative name, or email'|trans }}"
                           data-model="debounce(300)|search"
                           value="{{ this.search }}">
                </div>
            </div>
        </div>
    </div>

    <div class="panel">
        <div class="panel-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>
                                {% include 'partials/application/sort-header.html.twig' with {
                                    'label': 'Company'|trans,
                                    'column': 'company',
                                    'currentSort': this.sort,
                                    'currentDirection': this.direction,
                                } only %}
                            </th>
                            <th>
                                {% include 'partials/application/sort-header.html.twig' with {
                                    'label': 'Representative'|trans,
                                    'column': 'name',
                                    'currentSort': this.sort,
                                    'currentDirection': this.direction,
                                } only %}
                            </th>
                            <th>
                                {% include 'partials/application/sort-header.html.twig' with {
                                    'label': 'Email'|trans,
                                    'column': 'email',
                                    'currentSort': this.sort,
                                    'currentDirection': this.direction,
                                } only %}
                            </th>
                            <th>{{ 'MFA'|trans }}</th>
                            <th class="text-end">{{ 'Actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in this.rows %}
                            <tr>
                                <td><strong>{{ row.companyName }}</strong></td>
                                <td>{{ row.representativeName }}</td>
                                <td><code class="small">{{ row.representativeEmail }}</code></td>
                                <td>
                                    {% if row.mfaEnabled %}
                                        <span class="badge badge-success"><i class="fas fa-shield-halved"></i> {{ 'Enabled'|trans }}</span>
                                    {% else %}
                                        <span class="badge badge-secondary">{{ 'Disabled'|trans }}</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a href="{{ path('admin/users/company-users/sessions', {'id': row.id}) }}"
                                           class="btn btn-outline-secondary">
                                            <i class="fas fa-display"></i> {{ 'Sessions'|trans }}
                                        </a>
                                        <button type="button"
                                                class="btn btn-outline-warning"
                                                {% if not row.mfaEnabled %}disabled{% endif %}
                                                data-bs-toggle="modal" data-bs-target="#modal-admin-company-mfa-reset"
                                                data-action="{{ path('admin/users/company-users/mfa/reset', {'id': row.id}) }}"
                                                data-name="{{ row.companyName }}"
                                                data-csrf-token="{{ csrf_token('admin_mfa_reset-' ~ row.id) }}">
                                            <i class="fas fa-rotate-left"></i> {{ 'Reset MFA'|trans }}
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">{{ 'No company users match the current filters.'|trans }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% include 'partials/application/pagination.html.twig' with {
                'page': this.page,
                'totalPages': this.totalPages,
                'totalCount': this.totalCount,
            } only %}
        </div>
    </div>

    <div class="modal fade" id="modal-admin-company-mfa-reset" data-controller="modal-form-target" tabindex="-1" aria-labelledby="modal-admin-company-mfa-reset-label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modal-admin-company-mfa-reset-label">{{ 'Reset MFA?'|trans }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                </div>
                <form data-modal-form-target-target="form" method="POST" action="">
                    <div class="modal-body">
                        <p>
                            {{ 'You are about to reset multi-factor authentication for:'|trans }}
                            <strong data-modal-form-target-target="name"></strong>
                        </p>
                        <p class="mb-0 small text-muted">
                            {{ 'Their TOTP secret and backup codes will be discarded and every active session for the user will be terminated. Use this when a device has been lost or compromised.'|trans }}
                        </p>
                    </div>
                    <div class="modal-footer">
                        <input type="hidden" name="_csrf_token" value="" data-modal-form-target-target="csrfToken">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-rotate-left"></i> {{ 'Reset MFA'|trans }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

{# Renders the activity's sign-up lists (and each list's custom fields) as collapsible panels, reusing the same
   collapse strategy as the read-only accordion on the activity view page (templates/partials/activity/signup-list.html.twig):
   a `.panel` with a `.panel-heading` collapse toggle button, the rotating `.signup-list-chevron`, and a `.collapse.show`
   body. Each panel is open by default. Add/remove is driven by the generic `form-collection` Stimulus controller;
   the prototype already contains the whole panel, so adding an entry clones it with its placeholder (`__list__` /
   `__field__`) replaced by a fresh index, keeping the collapse target ids unique. The nested option collection keeps the
   generic `collection` form theme. #}

{# --- Sign-up list --------------------------------------------------------------------------------------------- #}
{% macro signup_list_panel(child, collapse_id, remove_label) %}
    <div class="panel mb-3" data-form-collection-target="entry">
        <button type="button"
                class="panel-heading signup-list-heading d-flex justify-content-between align-items-center gap-2 w-100 border-0 bg-transparent text-start"
                data-bs-toggle="collapse" data-bs-target="#{{ collapse_id }}"
                aria-expanded="true" aria-controls="{{ collapse_id }}">
            <span class="h6 mb-0">{{ 'Sign-up list'|trans }} <span class="signup-list-number"></span></span>
            <i class="fas fa-chevron-down signup-list-chevron"></i>
        </button>
        <div class="collapse show" id="{{ collapse_id }}">
            <div class="panel-body" data-controller="signup-list">
                <div class="row">
                    <div class="col-md-3">
                        {{ form_row(child.openDate) }}
                        {{ form_row(child.closeDate) }}
                        {{ form_row(child.onlyGEWIS) }}
                        {{ form_row(child.displaySubscribedNumber) }}
                        {{ form_row(child.promoted) }}
                        {{ form_row(child.limitedCapacity, {'attr': {
                            'data-signup-list-target': 'limited',
                            'data-action': 'change->signup-list#apply',
                        }}) }}
                        <div data-signup-list-target="capacity">
                            {{ form_row(child.capacity) }}
                        </div>
                        {# Allocation method + its per-method settings; shown only when limited, and only the selected
                           method's (and cutoff rule's) sub-fields, driven by the signup-list controller. #}
                        <div data-signup-list-target="methodBlock">
                            {{ form_row(child.allocationMethod, {'attr': {
                                'data-signup-list-target': 'method',
                                'data-action': 'change->signup-list#apply',
                            }}) }}
                            <div data-signup-list-target="conditional">
                                {{ form_row(child.drawCutoffRule, {'attr': {
                                    'data-signup-list-target': 'rule',
                                    'data-action': 'change->signup-list#apply',
                                }}) }}
                                <div data-signup-list-target="cutoffAt">{{ form_row(child.drawCutoffAt) }}</div>
                                <div data-signup-list-target="durationHours">{{ form_row(child.drawAfterDurationHours) }}</div>
                            </div>
                            <div data-signup-list-target="external">
                                {{ form_row(child.externalPolicyUrl) }}
                                {{ form_row(child.externalForceOrdering) }}
                                {{ form_row(child.externalPaymentByExternal) }}
                            </div>
                            <div data-signup-list-target="custom">
                                {{ form_row(child.customMethodDescription) }}
                            </div>
                        </div>
                    </div>
                    <div class="col-md-auto d-none d-md-flex px-0"><div class="vr"></div></div>
                    <div class="col-md">
                        {{ form_row(child.name) }}
                        {{ form_row(child.fields) }}
                    </div>
                </div>
                {{ form_rest(child) }}
                {# A list with sign-ups (here or on its live lineage counterpart) is frozen and must not be removed. #}
                {% if not child.vars.frozen %}
                    <button type="button" class="btn btn-sm btn-outline-gewis-primary mt-2"
                            data-action="form-collection#remove">
                        <i class="fas fa-trash"></i> {{ remove_label }}
                    </button>
                {% endif %}
            </div>
        </div>
    </div>
{% endmacro %}

{% block signup_list_collection_widget %}
    {% import _self as helper %}
    {% set has_prototype = allow_add and prototype is defined and prototype is not null %}
    {% set placeholder = has_prototype ? (prototype.vars.name|split('[')|last|trim(']')) : '__list__' %}
    {% set remove_label = 'Remove sign-up list'|trans %}
    <div id="{{ id }}" class="signup-list-collection"
         data-controller="form-collection"
         data-form-collection-prototype-name-value="{{ placeholder }}"
         {% if has_prototype %}
             data-form-collection-prototype-value="{{ helper.signup_list_panel(prototype, 'signup-list-' ~ placeholder, remove_label)|e('html_attr') }}"
         {% endif %}>
        <div data-form-collection-target="entries">
            {% for child in form %}
                {{ helper.signup_list_panel(child, 'signup-list-' ~ loop.index0, remove_label) }}
            {% endfor %}
        </div>
        {% if allow_add %}
            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="form-collection#add">
                <i class="fas fa-plus"></i> {{ 'Add a sign-up list'|trans }}
            </button>
        {% endif %}
    </div>
{% endblock %}

{# --- Custom field (question) ---------------------------------------------------------------------------------- #}
{% macro signup_field_panel(child, collapse_id, remove_label) %}
    <div class="panel mb-3" data-form-collection-target="entry">
        <button type="button"
                class="panel-heading signup-list-heading d-flex justify-content-between align-items-center gap-2 w-100 border-0 bg-transparent text-start"
                data-bs-toggle="collapse" data-bs-target="#{{ collapse_id }}"
                aria-expanded="true" aria-controls="{{ collapse_id }}">
            <span class="h6 mb-0">{{ 'Question'|trans }} <span class="signup-field-number"></span></span>
            <i class="fas fa-chevron-down signup-list-chevron"></i>
        </button>
        <div class="collapse show" id="{{ collapse_id }}">
            {# signup-field shows the min/max bounds only for a "number" field and the options only for a "choice"
               field, seeding/clearing the options as the type changes. #}
            <div class="panel-body" data-controller="signup-field">
                {{ form_row(child.name) }}
                <div class="row align-items-center mb-2">
                    <div class="col-md-6">{{ form_row(child.type, {'attr': {
                        'data-signup-field-target': 'type',
                        'data-action': 'change->signup-field#typeChanged',
                    }}) }}</div>
                    <div class="col-md-6">{{ form_row(child.isSensitive) }}</div>
                </div>
                <div data-signup-field-target="number">
                    <div class="row">
                        <div class="col-md-6">{{ form_row(child.minimumValue) }}</div>
                        <div class="col-md-6">{{ form_row(child.maximumValue) }}</div>
                    </div>
                </div>
                <div data-signup-field-target="choice">
                    {{ form_row(child.options, {'add_label': 'Add option'|trans, 'remove_label': 'Remove option'|trans}) }}
                </div>
                {{ form_rest(child) }}
                {# A frozen list's fields collection is disabled and ignores its submissions, so don't offer remove. #}
                {% if not child.vars.disabled %}
                    <button type="button" class="btn btn-sm btn-outline-gewis-primary mt-2"
                            data-action="form-collection#remove">
                        <i class="fas fa-trash"></i> {{ remove_label }}
                    </button>
                {% endif %}
            </div>
        </div>
    </div>
{% endmacro %}

{% block signup_field_collection_widget %}
    {% import _self as helper %}
    {% set has_prototype = allow_add and prototype is defined and prototype is not null %}
    {% set placeholder = has_prototype ? (prototype.vars.name|split('[')|last|trim(']')) : '__field__' %}
    {% set remove_label = 'Remove question'|trans %}
    <div id="{{ id }}" class="signup-field-collection"
         data-controller="form-collection"
         data-form-collection-prototype-name-value="{{ placeholder }}"
         {% if has_prototype %}
             data-form-collection-prototype-value="{{ helper.signup_field_panel(prototype, prototype.vars.id ~ '-collapse', remove_label)|e('html_attr') }}"
         {% endif %}>
        <div data-form-collection-target="entries">
            {% for child in form %}
                {{ helper.signup_field_panel(child, child.vars.id ~ '-collapse', remove_label) }}
            {% endfor %}
        </div>
        {# A frozen list's fields collection is disabled and ignores its submissions, so don't offer to add either. #}
        {% if allow_add and not disabled %}
            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="form-collection#add">
                <i class="fas fa-plus"></i> {{ 'Add a question'|trans }}
            </button>
        {% endif %}
    </div>
{% endblock %}

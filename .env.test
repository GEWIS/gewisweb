# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# Fake-but-parseable values so the test kernel can compile without the external services (locally compose.yaml's
# x-app-environment injects the real ones, which override these). Connections are lazy, so the GEWISDB/Valkey/Mercure
# hosts are never contacted. DATABASE_DSN points at a MariaDB matching production: integration tests need the real
# engine because custom DQL functions, named locks and MariaDB-specific column types cannot be reproduced on SQLite.
# CI runs a MariaDB service on 127.0.0.1; the `when@test` doctrine config isolates tests onto a separate `_test` db.
DATABASE_DSN='pdo-mysql://gewis:gewis@127.0.0.1:3306/gewis?serverVersion=11.8.3-mariadb&charset=utf8mb4&collation=utf8mb4_uca1400_ai_ci'
GEWISDB_DATABASE_DSN='pgsql://gewisdb:gewisdb@127.0.0.1:5432/gewisdb?sslmode=require&charset=utf8'
VALKEY_DSN='valkey://127.0.0.1:6379'
MERCURE_URL='http://mercure/.well-known/mercure'
MERCURE_PUBLIC_URL='http://localhost/.well-known/mercure'
MERCURE_JWT_SECRET='thisisnotsecret'
MAIL_FROM_ADDRESS='noreply@example.com'
VAR_DUMPER_SERVER='127.0.0.1:9912'
GEWISDB_API_HOST='https://database.test.gewis.nl/api'
GEWISDB_API_KEY='thiskeyisnotvalid'

# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# Fake-but-parseable values so the test kernel can compile in CI without external services (locally these are injected
# by compose.yaml's x-app-environment). Connections are lazy, so nothing actually reaches out to these hosts. SQLite is
# used for the relational DSNs so that future integration tests can target a real in-process database without standing
# up MariaDB or Postgres in CI.
DATABASE_DSN='pdo-sqlite:///:memory:'
GEWISDB_DATABASE_DSN='pdo-sqlite:///:memory:'
VALKEY_DSN='valkey://127.0.0.1:6379'
MERCURE_URL='http://mercure/.well-known/mercure'
MERCURE_PUBLIC_URL='http://localhost/.well-known/mercure'
MERCURE_JWT_SECRET='thisisnotsecret'
MAIL_FROM_ADDRESS='noreply@example.com'
VAR_DUMPER_SERVER='127.0.0.1:9912'
GEWISDB_API_HOST='https://database.test.gewis.nl/api'
GEWISDB_API_KEY='thiskeyisnotvalid'

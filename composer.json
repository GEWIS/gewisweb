{
    "name": "gewis/gewisweb",
    "description": "GEWIS Website",
    "type": "project",
    "license": "GPL-3.0-only",
    "homepage": "https://gewis.nl/",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.5",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "api-platform/doctrine-orm": "^4.3.6",
        "api-platform/symfony": "^4.3.6",
        "cweagans/composer-patches": "^2.0.0",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0.0",
        "doctrine/orm": "^3.6.7",
        "doctrineencryptbundle/doctrine-encrypt-bundle": "^7.0.3",
        "dragonmantank/cron-expression": "^3.6",
        "endroid/qr-code-bundle": "^7.0.1",
        "fortawesome/font-awesome": "^7.2.0",
        "jfcherng/php-diff": "^7.0",
        "league/commonmark": "^2.8",
        "matomo/device-detector": "^6.5.1",
        "nelmio/cors-bundle": "^2.6.1",
        "nelmio/security-bundle": "^3.9",
        "nikic/php-parser": "^5.7.0",
        "phpdocumentor/reflection-docblock": "^6.0.3",
        "phpseclib/phpseclib": "^3.0.52",
        "phpstan/phpdoc-parser": "^2.3.2",
        "scheb/2fa-backup-code": "^8.5",
        "scheb/2fa-bundle": "^8.5",
        "scheb/2fa-totp": "^8.5",
        "sensiolabs/typescript-bundle": "^0.2.2",
        "symfony/amqp-messenger": "8.0.*",
        "symfony/asset": "8.0.*",
        "symfony/asset-mapper": "8.0.*",
        "symfony/console": "8.0.*",
        "symfony/doctrine-messenger": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/expression-language": "8.0.*",
        "symfony/flex": "^2.10.0",
        "symfony/form": "8.0.*",
        "symfony/framework-bundle": "8.0.*",
        "symfony/http-client": "8.0.*",
        "symfony/intl": "8.0.*",
        "symfony/lock": "8.0.*",
        "symfony/mailer": "8.0.*",
        "symfony/mercure": "^0.7.2",
        "symfony/mercure-bundle": "^0.4.2",
        "symfony/messenger": "8.0.*",
        "symfony/mime": "8.0.*",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/notifier": "8.0.*",
        "symfony/process": "8.0.*",
        "symfony/property-access": "8.0.*",
        "symfony/property-info": "8.0.*",
        "symfony/rate-limiter": "8.0.*",
        "symfony/redis-messenger": "8.0.*",
        "symfony/runtime": "8.0.*",
        "symfony/scheduler": "8.0.*",
        "symfony/security-bundle": "8.0.*",
        "symfony/security-csrf": "8.0.*",
        "symfony/serializer": "8.0.*",
        "symfony/stimulus-bundle": "^3.0.0",
        "symfony/string": "8.0.*",
        "symfony/translation": "8.0.*",
        "symfony/twig-bundle": "8.0.*",
        "symfony/uid": "8.0.*",
        "symfony/ux-calendar-link": "3.1.0",
        "symfony/ux-live-component": "3.1.0",
        "symfony/validator": "8.0.*",
        "symfony/web-link": "8.0.*",
        "symfony/workflow": "8.0.*",
        "symfony/yaml": "8.0.*",
        "symfonycasts/sass-bundle": "^0.10.0",
        "tito10047/altcha-bundle": "^3.1",
        "twbs/bootstrap": "^5.3.8",
        "twig/extra-bundle": "^3.24.0",
        "twig/intl-extra": "^3.26.0",
        "twig/twig": "^3.27.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        },
        "bump-after-update": true,
        "preferred-install": {
            "doctrine/orm": "source",
            "symfony/ux-live-component": "source",
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/GEWIS/gewisphp-coding-standards.git"
        }
    ],
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts",
            "@assets:update"
        ],
        "post-update-cmd": [
            "@auto-scripts",
            "@assets:update"
        ],
        "assets:update": [
            "rm -rf assets/fonts/fontawesome/*",
            "rm -rf assets/sprites/fontawesome/*",
            "cp -r vendor/fortawesome/font-awesome/webfonts/. assets/fonts/fontawesome/",
            "cp -r vendor/fortawesome/font-awesome/sprites/. assets/sprites/fontawesome/",
            "rm -f assets/js/bootstrap.bundle.min.js",
            "cp vendor/twbs/bootstrap/dist/js/bootstrap.bundle.min.js assets/js"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "patches": {
            "doctrine/orm": {
                "Fix issues with SubDecisions.": "https://raw.githubusercontent.com/GEWIS/orm/3.6.x/1-to-1-multiple-join-columns.patch"
            },
            "symfony/ux-live-component": {
                "Fix data-loadig not ignored data-live-ignore": "https://raw.githubusercontent.com/GEWIS/symfony-ux-live-component/refs/heads/3.x/data-loading-not-ignored.patch"
            }
        },
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*",
            "docker": true
        }
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "fakerphp/faker": "^1.24.1",
        "gewis/gewisphp-coding-standards": "2.0.1",
        "igor-php/igor-php": "^0.6.3",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0.4",
        "phpstan/phpstan-doctrine": "^2.0.22",
        "phpstan/phpstan-phpunit": "^2.0.16",
        "phpstan/phpstan-strict-rules": "^2.0.11",
        "phpstan/phpstan-symfony": "^2.0.18",
        "phpunit/phpunit": "^13.1.13",
        "psalm/plugin-phpunit": "^0.19.7",
        "psalm/plugin-symfony": "^5.3.0",
        "symfony/browser-kit": "8.0.*",
        "symfony/css-selector": "8.0.*",
        "symfony/debug-bundle": "8.0.*",
        "symfony/maker-bundle": "^1.67.0",
        "symfony/phpunit-bridge": "^8.0.8",
        "symfony/stopwatch": "8.0.*",
        "symfony/web-profiler-bundle": "8.0.*",
        "symplify/config-transformer": "^12.5.0",
        "vimeo/psalm": "^6.16.1",
        "weirdan/doctrine-psalm-plugin": "^2.10"
    }
}

# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# Production env vars are injected by the orchestrator (Portainer / Rancher-k3s) and validated by `${VAR:?...}` in
# compose.production.yaml.

###> symfony/framework-bundle ###
APP_ENV=dev
# APP_SECRET intentionally not set here. It is supplied by .env.local in dev and by the orchestrator in prod (see
# compose.production.yaml).
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# DATABASE_DSN and GEWISDB_DATABASE_DSN are built from parts in compose.yaml (x-app-environment). Override individual
# parts via .env.local or set the full DSN directly.
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
MESSENGER_TRANSPORT_DSN=in-memory://
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=smtp://mailer:1025
###< symfony/mailer ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/mercure-bundle ###
# Values are injected by compose.yaml (`x-app-environment`); overrideable via .env.local for dev or the orchestrator's
# env for prod.
###< symfony/mercure-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

MATOMO_DOMAIN=http://localhost:82

# Dev-only toggle: enforce MFA enrolment for administrators and current board members. Edit in .env.local to disable.
MFA_ENFORCEMENT=true

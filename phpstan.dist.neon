includes:
    - phpstan-baseline.neon

parameters:
    level: 6
    bootstrapFiles:
        - tests/bootstrap.php
    doctrine:
        objectManagerLoader: tests/object-manager.php
        ormRepositoryClass: App\Entity
        # Allow a nullable PHP property to back a NOT NULL column: a field may be transiently null (e.g. an activity
        # revision's schedule before the create form is filled in) yet is guaranteed non-null on persist by a NotBlank
        # constraint, so the column stays NOT NULL while the property type stays honest about the empty draft state.
        allowNullablePropertyForRequiredField: true
    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
#    scanDirectories:
#        - var/cache/dev/Symfony/Config
    scanFiles:
        - vendor/symfony/dependency-injection/Loader/Configurator/ContainerConfigurator.php
    paths:
        - bin/
        - config/
        - public/
        - src/
        - tests/
    excludePaths:
        - config/reference.php
    strictRules:
        disallowedImplicitArrayCreation: false
        overwriteVariablesWithLoop: false
        noVariableVariables: false

# Local development environment. Copy this file to .env.local and edit the values marked REQUIRED. Everything else has a
# working default in compose.yaml (named `${VAR:-default}`). You only need to override it if your setup differs.
#
# Production (Portainer / Rancher-k3s) does NOT use this file: the orchestrator injects environment variables directly,
# and compose.production.yaml marks the must-set ones as required (`${VAR:?...}`) so a missing value aborts startup.

# REQUIRED — generate with `openssl rand -hex 32`
APP_SECRET=ThisTokenIsNotSoSecretChangeIt

# REQUIRED — Mercure hub JWT signing secret (any high-entropy string)
MERCURE_JWT_SECRET=example2b2e69207bcc49596afbf4f1fd59399fd1ed38682dec4a94378fc0409540ca596d0889b990c7a6edf3920edcddbce6217e58ecbb80d7f0210fade6926
MERCURE_URL=http://web/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost/.well-known/mercure

# REQUIRED — GEWISDB API for membership lookups
GEWISDB_API_HOST=https://database.test.gewis.nl/api
GEWISDB_API_KEY='thiskeyisnotvalid'

# Mail
MAIL_FROM_ADDRESS=example@example.com

# Application database (Symfony app). DATABASE_DSN is built from these by compose.yaml; only override DATABASE_DSN
# itself if you need a non-standard DSN.
DOCKER_DB_HOST=mariadb
DOCKER_DB_PORT=3306
DOCKER_DB_USERNAME=gewis
DOCKER_DB_PASSWORD=gewis
DOCKER_DB_DATABASE=gewis
DOCKER_DB_VERSION=''

# Membership data (read-only Postgres on the gewisdb side). TLS is required by the GEWISDB Postgres server, so
# `sslmode=require` remains in the constructed DSN.
GEWISDB_DB_HOST=postgres
GEWISDB_DB_PORT=5432
GEWISDB_DB_USERNAME=gewisdb
GEWISDB_DB_PASSWORD=gewisdb
GEWISDB_DB_DATABASE=gewisdb

# MariaDB container (dev-only, used by compose.override.yaml).
MARIADB_ROOT_PASSWORD=gewis
MARIADB_DATABASE=gewis
MARIADB_USER=gewis
MARIADB_PASSWORD=gewis
MARIADB_ALLOW_EMPTY_PASSWORD='yes'

# PhpMyAdmin (dev-only).
PMA_HOST=mariadb
PMA_USER=gewis
PMA_PASSWORD=gewis

# Matomo (dev-only).
MATOMO_DATABASE_ADAPTER=mariadb
MATOMO_DATABASE_HOST=mariadb
MATOMO_DATABASE_USERNAME=matomo
MATOMO_DATABASE_PASSWORD=matomo
MATOMO_DATABASE_DBNAME=matomo
MATOMO_DATABASE_SSL=0
MATOMO_DOMAIN=http://localhost:82

# Production-only: public archive sync over SSH. Safe to leave at the placeholder values in dev as long as the
# SyncPublicArchiveCommand is not invoked locally.
SSH_USERNAME=gewis
SSH_PASSWORD=gewis
SSH_REMOTE=gewis

# Glide image server (post-migration; currently only the Laminas tree uses these)
GLIDE_HOST=http://localhost:81
GLIDE_KEY='v-LK4WCdhcfcc%jt*VC2cj%nVpu+xQKvLUA%H86kRVk_4bgG8&CWM#k*b_7MUJpmTc=4GFmKFp7=K%67je-skxC5vz+r#xT?62tT?Aw%FtQ4Y3gvnwHTwqhxUh89wCa_'

# Activity creation / organ update / poll creation mail routing
MAIL_TO_ACTIVITY_CREATION_ADDRESS=example@example.com
MAIL_TO_ACTIVITY_CREATION_NAME=ApplicatieBeheerCommissie
MAIL_TO_ACTIVITY_CREATION_REQUIRE_GEFLITST_ADDRESS=example@example.com
MAIL_TO_ACTIVITY_CREATION_REQUIRE_GEFLITST_NAME=ApplicatieBeheerCommissie
MAIL_TO_ACTIVITY_CREATION_REQUIRE_GEFLITST_PLANKA_ADDRESS=example@example.com
MAIL_TO_ACTIVITY_CREATION_REQUIRE_GEFLITST_PLANKA_KEY=933632049134645737638108890119485901261134
MAIL_TO_ACTIVITY_CREATION_REQUIRE_GEFLITST_PLANKA_NAME=ApplicatieBeheerCommissie
MAIL_TO_ACTIVITY_CREATION_REQUIRE_ZETTLE_ADDRESS=example@example.com
MAIL_TO_ACTIVITY_CREATION_REQUIRE_ZETTLE_NAME=ApplicatieBeheerCommissie
MAIL_TO_ACTIVITY_CALENDAR_ADDRESS=example@example.com
MAIL_TO_ACTIVITY_CALENDAR_NAME=ApplicatieBeheerCommissie
MAIL_TO_ORGAN_UPDATE_ADDRESS=example@example.com
MAIL_TO_ORGAN_UPDATE_NAME=ApplicatieBeheerCommissie
MAIL_TO_POLL_CREATION_ADDRESS=example@example.com
MAIL_TO_POLL_CREATION_NAME=ApplicatieBeheerCommissie

# Google Calendar (Option Calendar)
DOCKER_GOOGLE_API_KEY=unknown
DOCKER_GOOGLE_CALENDAR_KEY=unknown

# Supremum Infima API (production only)
DOCKER_SUPREMUM_API_KEY=unknown

# Course documents watermarking
WATERMARK_TAG=test123

# Dev-only: disable forced MFA enrolment for administrators/board members locally so the seeded admin account can log in
# without setting up TOTP after every database reset. Only honoured by `when@dev:` in config/services.yaml; production
# hardcodes enforcement on regardless of this var. FrankenPHP's worker mode caches the resolved value, so you must run
# `docker compose restart web` after flipping it for the change to take effect.
MFA_ENFORCEMENT=false

# External-application JWT signing key set (development only). A JWKSet holding one key per asymmetric family: an
# Ed25519 key for EdDSA, a P-521 key for ES512, and an RSA key shared by PS512 and RS512. These are throwaway keys, safe
# to ship in this template; production injects its own set through the orchestrator. There is deliberately no default in
# `.env`, so an environment without this variable fails loudly rather than signing with an empty key set.
